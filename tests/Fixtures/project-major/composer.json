        "bitbag/sylius-elasticsearch-plugin": "^1.0",
        "bitbag/sylius-shipping-export-plugin": "^1.0",
        "sylius/invoicing-plugin": "^0.20",
        "sylius/refund-plugin": "^1.2",
        "setono/sylius-analytics-plugin": "^3.0",
        "mangoweb-sylius/sylius-extended-channels": "^0.5",
