{% extends '@SyliusShop/layout.html.twig' %}

{% block content %}
<div class="ui segment">
    <h1 class="ui header">{{ 'sylius.ui.cart'|trans }}</h1>
    <table class="ui celled table">
        <thead>
            <tr>
                <th>{{ 'sylius.ui.product'|trans }}</th>
                <th>{{ 'sylius.ui.unit_price'|trans }}</th>
                <th>{{ 'sylius.ui.quantity'|trans }}</th>
                <th>{{ 'sylius.ui.total'|trans }}</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            {% for item in cart.items %}
            <tr>
                <td>{{ item.productName }}</td>
                <td>{{ item.unitPrice|sylius_price }}</td>
                <td>
                    <div class="ui input">
                        <input type="number" value="{{ item.quantity }}" min="1"/>
                    </div>
                </td>
                <td>{{ item.total|sylius_price }}</td>
                <td>
                    <button class="ui red button"><i class="trash icon"></i></button>
                </td>
            </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr>
                <th colspan="3" class="right aligned">{{ 'sylius.ui.total'|trans }}</th>
                <th>{{ cart.total|sylius_price }}</th>
                <th></th>
            </tr>
        </tfoot>
    </table>
    <a href="{{ path('sylius_shop_checkout_start') }}" class="ui primary large button">
        {{ 'sylius.ui.checkout'|trans }}
    </a>
</div>
{% endblock %}
