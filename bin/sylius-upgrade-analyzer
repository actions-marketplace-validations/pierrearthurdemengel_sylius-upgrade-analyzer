#!/usr/bin/env php
<?php

declare(strict_types=1);

// Recherche l'autoloader Composer dans le projet courant ou en mode vendor
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

$autoloaderFound = false;
foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require $autoloadPath;
        $autoloaderFound = true;
        break;
    }
}

if (!$autoloaderFound) {
    fwrite(STDERR, "Autoloader introuvable. Lancez 'composer install' d'abord.\n");
    exit(1);
}

use PierreArthur\SyliusUpgradeAnalyzer\Command\AnalyzeCommand;
use Symfony\Component\Console\Application;

$application = new Application('sylius-upgrade-analyzer', '1.0.0');
$application->add(new AnalyzeCommand());
$application->setDefaultCommand('sylius-upgrade:analyze');
$application->run();
